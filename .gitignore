# Local environment and secrets
.env
.env.*
!.env.example

# Local agent/editor state
.agents/
.claude/
.codex/
skills-lock.json
.vscode/
.idea/

# Runtime and temporary files
*.log
*.tmp
*.cache
Thumbs.db
.DS_Store

# User-uploaded content (keep directory protection files)
uploads/*
!uploads/.htaccess
!uploads/notices/
!uploads/students/
uploads/notices/*
uploads/students/*
!uploads/notices/.htaccess
!uploads/students/.htaccess

# Composer / vendor libraries (install per-server with `composer install`)
vendor/

# Production deploy bundle (regenerated from this repo, not stored in it)
build/

# Database dumps — never commit (PII + secrets)
*.sql
!sql/*.sql
csf_portal_dump.sql

# Ad-hoc live-DB debug scripts (db_setup.php / db_verify.php / db_dept_check.php /
# db_fix_seed_hashes.php / sql/fix-seed-hashes.php are intentionally tracked)
